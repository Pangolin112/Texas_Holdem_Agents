# Copy this file to .env and fill in your key (the .env file is gitignored).
OPENAI_API_KEY=sk-your-key-here

# Optional: which model powers the opponents (default: gpt-5.2).
# If the chosen model isn't on your account, the game auto-falls back
# (gpt-5.1 -> gpt-5 -> gpt-5-mini -> gpt-4o-mini). gpt-4o-mini is cheapest.
# OPENAI_MODEL=gpt-5.2

# Optional: custom API endpoint (proxies / compatible providers).
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- DeepSeek (OpenAI-compatible) -------------------------------------------
# DeepSeek works through the same three variables — point them at its endpoint
# and use a deepseek-* model. The game detects DeepSeek from the base URL /
# model id and falls back within the deepseek family (never to a gpt-* id the
# endpoint doesn't serve). Note: DeepSeek has no TTS endpoint, so the web app's
# agent voices fall back to the browser's own speech synthesis.
#
#   OPENAI_API_KEY=sk-your-deepseek-key
#   OPENAI_BASE_URL=https://api.deepseek.com
#   OPENAI_MODEL=deepseek-chat        # or deepseek-reasoner, or your provider's id
