# Copy this file to .env and fill in your key (the .env file is gitignored).
OPENAI_API_KEY=sk-your-key-here

# Optional: which model powers the opponents (default: gpt-5-mini).
# Use gpt-5 for even sharper play, or gpt-4o-mini for the cheapest game.
# OPENAI_MODEL=gpt-5-mini

# Optional: custom API endpoint (proxies / compatible providers).
# OPENAI_BASE_URL=https://api.openai.com/v1
